@page
@model HotelManagementSystem.Web.Pages.MyReservationsModel
@{
    ViewData["Title"] = "Đặt phòng của tôi";
}

<style>
    .ls-wide { letter-spacing: .07em; }
</style>

<div class="container py-4">

    <div class="mb-4">
        <h4 class="fw-bold mb-1">
            <i class="bi bi-journal-check me-2 text-primary"></i>Đặt phòng của tôi
        </h4>
        <p class="text-muted small mb-0">Xem lịch sử đặt phòng và yêu cầu hoàn tiền.</p>
    </div>

    @if (TempData["SuccessMessage"] is string successMsg)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@successMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errorMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Reservations.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 text-center p-5">
            <i class="bi bi-inbox text-muted" style="font-size:3rem"></i>
            <h5 class="text-muted mt-3">Chưa có đặt phòng nào</h5>
            <p class="text-muted small">Hãy đặt phòng để bắt đầu trải nghiệm!</p>
            <a asp-page="/Rooms" class="btn btn-primary rounded-3 px-4 mx-auto" style="width:fit-content">
                <i class="bi bi-search me-1"></i>Tìm phòng
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var reservation in Model.Reservations)
            {
                var payment = reservation.Payments.FirstOrDefault();
                var refundDeadline  = MyReservationsModel.GetRefundDeadline(reservation);
                var isRefundEligible = MyReservationsModel.IsRefundEligible(reservation);
                var hoursLeft = (refundDeadline - DateTime.Now).TotalHours;
                var canShowRefund = reservation.Status == "Confirmed" && payment?.Status == "Completed";
                var statusClass = reservation.Status switch
                {
                    "Confirmed" => "success",
                    "PendingPayment" => "warning",
                    "CheckedIn" => "info",
                    "CheckedOut" => "secondary",
                    "Cancelled" => "danger",
                    _ => "secondary"
                };
                var statusText = reservation.Status switch
                {
                    "Confirmed" => "Đã xác nhận",
                    "PendingPayment" => "Chờ thanh toán",
                    "CheckedIn" => "Đã nhận phòng",
                    "CheckedOut" => "Đã trả phòng",
                    "Cancelled" => "Đã hủy",
                    _ => reservation.Status
                };

                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                        <div class="card-body p-4">
                            <div class="row align-items-center">

                                <!-- Room info -->
                                <div class="col-md-3">
                                    <div class="text-muted ls-wide" style="font-size:.6rem;text-transform:uppercase">Phòng</div>
                                    <div class="fw-bold fs-5">@reservation.Room.RoomNumber</div>
                                    <div class="text-muted small">@reservation.Room.RoomType</div>
                                </div>

                                <!-- Dates -->
                                <div class="col-md-3">
                                    <div class="text-muted ls-wide" style="font-size:.6rem;text-transform:uppercase">Thời gian</div>
                                    <div class="small">
                                        <i class="bi bi-calendar2-check text-success me-1"></i>
                                        @reservation.CheckInDate.ToString("dd/MM/yyyy")
                                    </div>
                                    <div class="small">
                                        <i class="bi bi-calendar2-x text-danger me-1"></i>
                                        @reservation.CheckOutDate.ToString("dd/MM/yyyy")
                                    </div>
                                    @if (canShowRefund)
                                    {
                                        <div class="small mt-1">
                                            @if (isRefundEligible)
                                            {
                                                if (hoursLeft <= 24)
                                                {
                                                    <span class="text-warning fw-semibold">
                                                        <i class="bi bi-clock-history me-1"></i>Hạn hoàn tiền: @refundDeadline.ToString("HH:mm dd/MM") <em class="fw-normal">(còn ~@((int)hoursLeft)h)</em>
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">
                                                        <i class="bi bi-clock me-1"></i>Hạn hoàn tiền: @refundDeadline.ToString("dd/MM/yyyy HH:mm")
                                                    </span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-danger">
                                                    <i class="bi bi-lock-fill me-1"></i>Hết hạn hoàn tiền
                                                </span>
                                            }
                                        </div>
                                    }
                                </div>

                                <!-- Payment info -->
                                <div class="col-md-3">
                                    <div class="text-muted ls-wide" style="font-size:.6rem;text-transform:uppercase">Thanh toán</div>
                                    @if (payment != null)
                                    {
                                        <div class="small">
                                            <span class="badge bg-light text-dark border">@payment.PaymentMethod</span>
                                            <span class="fw-bold ms-1">@payment.Amount.ToString("N0") ₫</span>
                                        </div>
                                        <div class="small text-muted">
                                            @switch (payment.Status)
                                            {
                                                case "Completed":
                                                    <span class="text-success"><i class="bi bi-check-circle me-1"></i>Đã thanh toán</span>
                                                    break;
                                                case "Pending":
                                                    <span class="text-warning"><i class="bi bi-clock me-1"></i>Đang xử lý</span>
                                                    break;
                                                case "Refunded":
                                                    <span class="text-info"><i class="bi bi-arrow-counterclockwise me-1"></i>Đã hoàn tiền</span>
                                                    break;
                                                case "Failed":
                                                    <span class="text-danger"><i class="bi bi-x-circle me-1"></i>Thất bại</span>
                                                    break;
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="small text-muted">—</div>
                                    }
                                </div>

                                <!-- Status + Actions -->
                                <div class="col-md-3 text-end">
                                    <span class="badge bg-@statusClass bg-opacity-10 text-@statusClass border border-@statusClass border-opacity-25 rounded-pill px-3 py-2 mb-2 d-inline-block">
                                        @statusText
                                    </span>

                                    @if (canShowRefund)
                                    {
                                        <div class="mt-2">
                                            @if (isRefundEligible)
                                            {
                                                <button type="button" class="btn btn-outline-danger btn-sm rounded-3"
                                                        data-bs-toggle="modal" data-bs-target="#refundModal-@reservation.Id">
                                                    <i class="bi bi-arrow-counterclockwise me-1"></i>Yêu cầu hoàn tiền
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-outline-secondary btn-sm rounded-3"
                                                        disabled
                                                        title="Không thể hoàn tiền trong vòng 48 giờ trước khi nhận phòng. Hạn chót: @refundDeadline.ToString("HH:mm dd/MM/yyyy")">
                                                    <i class="bi bi-lock-fill me-1"></i>Không thể hoàn tiền
                                                </button>
                                                <div class="text-muted mt-1" style="font-size:.65rem">
                                                    Đã qua hạn @refundDeadline.ToString("HH:mm dd/MM")
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>

                            @if (reservation.ReservationServices.Any())
                            {
                                <hr class="my-3" />
                                <div class="text-muted ls-wide mb-2" style="font-size:.6rem;text-transform:uppercase">Dịch vụ đã chọn</div>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var svc in reservation.ReservationServices)
                                    {
                                        <span class="badge bg-light text-dark border rounded-pill px-3 py-1">
                                            <i class="bi bi-check-circle text-success me-1"></i>@svc.HotelService.Name
                                            <span class="text-muted ms-1">(@svc.UnitPrice.ToString("N0") ₫)</span>
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @if (canShowRefund && isRefundEligible)
                {
                    <!-- Refund confirmation modal -->
                    <div class="modal fade" id="refundModal-@reservation.Id" tabindex="-1">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content rounded-4 border-0 shadow">
                                <div class="modal-header border-0 pb-0">
                                    <h5 class="modal-title fw-bold">
                                        <i class="bi bi-exclamation-triangle text-warning me-2"></i>Xác nhận hoàn tiền
                                    </h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <p>Bạn có chắc chắn muốn yêu cầu hoàn tiền cho đặt phòng <strong>@reservation.Room.RoomNumber</strong>?</p>
                                    <div class="bg-light rounded-3 p-3">
                                        <div class="d-flex justify-content-between small mb-1">
                                            <span class="text-muted">Phòng:</span>
                                            <span class="fw-bold">@reservation.Room.RoomNumber — @reservation.Room.RoomType</span>
                                        </div>
                                        <div class="d-flex justify-content-between small mb-1">
                                            <span class="text-muted">Ngày nhận:</span>
                                            <span>@reservation.CheckInDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <div class="d-flex justify-content-between small mb-1">
                                            <span class="text-muted">Ngày trả:</span>
                                            <span>@reservation.CheckOutDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <div class="d-flex justify-content-between small mb-1">
                                            <span class="text-muted">Số tiền hoàn:</span>
                                            <span class="fw-bold text-danger">@payment!.Amount.ToString("N0") ₫</span>
                                        </div>
                                        <div class="d-flex justify-content-between small">
                                            <span class="text-muted">Hạn hoàn tiền:</span>
                                            <span class="text-warning fw-semibold">@refundDeadline.ToString("HH:mm dd/MM/yyyy")</span>
                                        </div>
                                    </div>
                                    @if (payment!.PaymentMethod == "MoMo")
                                    {
                                        <div class="alert alert-info small mt-3 mb-0 rounded-3">
                                            <i class="bi bi-info-circle me-1"></i>
                                            Tiền sẽ được hoàn về ví MoMo của bạn.
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-warning small mt-3 mb-0 rounded-3">
                                            <i class="bi bi-info-circle me-1"></i>
                                            Đặt phòng sẽ được hủy. Vui lòng liên hệ lễ tân để hoàn tiền chuyển khoản.
                                        </div>
                                    }
                                </div>
                                <div class="modal-footer border-0 pt-0">
                                    <button type="button" class="btn btn-outline-secondary rounded-3" data-bs-dismiss="modal">Hủy bỏ</button>
                                    <form method="post" asp-page-handler="Refund" class="d-inline">
                                        <input type="hidden" name="reservationId" value="@reservation.Id" />
                                        <button type="submit" class="btn btn-danger rounded-3">
                                            <i class="bi bi-arrow-counterclockwise me-1"></i>Xác nhận hoàn tiền
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>
